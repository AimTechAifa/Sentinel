generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════
// TENANT ROOT
// Every org-scoped table below carries organizationId directly.
// Join/child tables (ReleaseApplication, LeaveRecordRelease, etc.) are
// intentionally NOT given their own organizationId — they inherit tenant
// scope through their parent FK, which is standard normalized practice
// and avoids duplicating the tenant key on every join row.
// ═══════════════════════════════════════════════════════════════════

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED, TRIAL
  isSystemGlobal Boolean @default(false) // true for exactly one reserved sentinel org holding system-default template rows
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments      Department[]
  applications     Application[]
  users            User[]
  releases         Release[]
  envBookings      EnvBooking[]
  risks            Risk[]
  drifts           Drift[]
  approvals        Approval[]
  leaveRecords     LeaveRecord[]
  calendarEvents   CalendarEvent[]
  monitoringAlerts MonitoringAlert[]
  incidents        Incident[]
  appStatusChecks  ApplicationStatusCheck[]
  plannedMaintenance PlannedMaintenance[]
  superAdmins      SuperAdminProfile[]
  connectors       Connector[]
  systemIntegrations SystemIntegration[]

  riskFactorDefinitions   RiskFactorDefinition[]
  riskScoreThresholds     RiskScoreThreshold[]
  riskLikelihoodScales    RiskLikelihoodScale[]
  riskImpactScales        RiskImpactScale[]
  slaMetricDefinitions    SLAMetricDefinition[]
  workflowStages          WorkflowStageDefinition[]
  approvalTypes           ApprovalTypeDefinition[]
  roleDefinitions         RoleDefinition[]
  testingPhaseGates       TestingPhaseGate[]
  notificationTypes       NotificationTypeDefinition[]
  releaseSizeDefinitions  ReleaseSizeDefinition[]
  changeFreezePeriods     ChangeFreezePeriod[]
  environmentTypes        EnvironmentTypeDefinition[]
  deploymentWindows       DeploymentWindowDefinition[]
  sharedEnvironmentConfigs SharedEnvironmentConfig[]
  applicationCategories   ApplicationCategoryDefinition[]
  customFieldDefinitions  CustomFieldDefinition[]
}

// ═══════════════════════════════════════════════════════════════════
// GROUP 1 — CORE ENTITY MASTERS
// ═══════════════════════════════════════════════════════════════════

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deptCode       String?
  name           String
  head           String
  primaryFocus   String?
  applications   Application[]
  releases       Release[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
}

model Application {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  departmentId   String
  department     Department           @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  type           String?              // no source data in workbook — optional until backfilled via ApplicationCategoryDefinition
  productOwner   String
  techLead       String
  support        String?
  criticality    String?              // backfill from ApplicationCategoryDefinition match, not guaranteed present
  customFields   Json?                @db.JsonB   // e.g. { "Vendor Contract": "...", "License Expiry": "..." }

  environments   Environment[]
  releaseLinks   ReleaseApplication[]
  bookings       EnvBooking[]
  mappingFrom    SystemMappingEdge[]  @relation("MappingSourceApp")
  mappingTo      SystemMappingEdge[]  @relation("MappingTargetApp")
  envVersions    EnvironmentVersion[]
  drifts         Drift[]
  monitoringAlerts MonitoringAlert[]
  incidents      Incident[]
  statusChecks   ApplicationStatusCheck[]
  plannedMaintenance PlannedMaintenance[]
  integrationsAsSource SystemIntegration[] @relation("IntegrationSource")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt               DateTime?           // soft delete — null means active; set instead of hard-deleting so Risk/Approval/Drift history is preserved

  @@unique([organizationId, name, departmentId])
  @@index([organizationId, departmentId])
  @@index([deletedAt])
}

model Environment {
  id            String              @id @default(cuid())
  applicationId String
  application   Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  type          String
  owner         String
  lastDbRefresh DateTime?
  status        String              @default("Active")
  customFields  Json?               @db.JsonB   // e.g. { "Hosting Provider": "AWS", "Instance Size": "m5.large" }
  bookings      EnvBooking[]
  mappingFrom   SystemMappingEdge[] @relation("MappingSourceEnv")
  mappingTo     SystemMappingEdge[] @relation("MappingTargetEnv")
  versions      EnvironmentVersion[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt               DateTime?           // soft delete — null means active; set instead of hard-deleting so Risk/Approval/Drift history is preserved

  @@unique([applicationId, name])
  @@index([applicationId, status])
  @@index([deletedAt])
}

model User {
  id              String               @id @default(cuid())
  organizationId  String
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  name            String
  email           String
  role            String
  department      String
  manager         String?
  accessLevel     String
  status          String
  lastLogin       DateTime?
  customFields    Json?                @db.JsonB   // e.g. { "Phone Extension": "1234", "Office Location": "..." }

  // Release Manager fields — folded in here rather than a separate model,
  // since the workbook's "Admin (Release Managers)" sheet is confirmed to
  // be the same people already present in Users (100% email match).
  region          String?
  phone           String?
  specialization  String?
  rmStartDate     DateTime?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  ownedReleases   Release[]            @relation("ReleaseOwner")
  risksOwned      Risk[]
  approvalsGiven  Approval[]
  leaveRecords    LeaveRecord[]
  stakeholderOf   ReleaseStakeholder[]
  superAdminLink  SuperAdminProfile?

  @@unique([organizationId, userId])
  @@unique([organizationId, email])
  @@index([organizationId, role])
  @@index([organizationId, status])
}

// Super Admins are kept separate from User — verified only 3 of 12 overlap
// with Users by email, so most (CIO, CTO, VP-level) are distinct people
// not otherwise represented as application users.
model SuperAdminProfile {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saCode         String
  name           String
  email          String
  title          String?
  departmentName String?
  accessScope    String?
  grantedDate    DateTime?
  grantedBy      String?
  status         String?
  expiryDate     DateTime?
  notes          String?
  linkedUserId   String?      @unique
  linkedUser     User?        @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, saCode])
  @@unique([organizationId, email])
}

// ═══════════════════════════════════════════════════════════════════
// RELEASES & CORE WORKFLOW
// ═══════════════════════════════════════════════════════════════════

model Release {
  id                    String               @id @default(cuid())
  organizationId        String
  organization          Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  releaseCode           String
  name                  String
  programProject        String?
  status                String
  releaseDate           DateTime
  priority              String
  impact                String
  departmentId          String
  department            Department           @relation(fields: [departmentId], references: [id])
  notes                 String?
  decision              String?
  customFields          Json?                @db.JsonB  // e.g. { "Release Notes URL": "...", "Budget Code": "..." }

  // Phase 1 fields
  releaseSize            String?
  cabDate                DateTime?
  startDate              DateTime?
  endDate                DateTime?           // was missing — confirmed required in the workbook (Start Date / End Date both present)
  testEnvRequired        String?
  uatEnvRequired         String?
  conflictFlag           Boolean             @default(false)
  readinessPercent       Float?
  blockers               String?
  vendorMaintenance      String?
  changeFreeze           String?
  regulatory             String?
  approvalStatus         String?
  rollbackPlan           String?
  goLiveChecklistPercent Float?
  deploymentWindow       String?
  releaseOwnerId         String?
  releaseOwner           User?               @relation("ReleaseOwner", fields: [releaseOwnerId], references: [id])

  applications          ReleaseApplication[]
  dependsOn             ReleaseDependency[]  @relation("ReleaseDependsOn")
  dependedBy            ReleaseDependency[]  @relation("ReleaseDependedBy")
  bookings              EnvBooking[]
  auditEvents           ReleaseAuditEvent[]
  risks                 Risk[]
  drifts                Drift[]
  approvals              Approval[]
  dependentLeaves        LeaveRecordRelease[]
  stakeholders           ReleaseStakeholder[]
  calendarEvents          CalendarEvent[]
  incidents               Incident[]
  riskMetrics             ReleaseRiskMetric[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?           // soft delete — null means active; set instead of hard-deleting so Risk/Approval/Drift history is preserved

  @@unique([organizationId, releaseCode])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, departmentId])
  @@index([organizationId, releaseOwnerId])
  @@index([deletedAt])
}

model ReleaseApplication {
  releaseId     String
  applicationId String
  release       Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([releaseId, applicationId])
}

model ReleaseDependency {
  id                 String  @id @default(cuid())
  releaseId          String
  dependsOnReleaseId String
  release            Release @relation("ReleaseDependsOn", fields: [releaseId], references: [id], onDelete: Cascade)
  dependsOnRelease   Release @relation("ReleaseDependedBy", fields: [dependsOnReleaseId], references: [id], onDelete: Cascade)
  dependencyType     String? // Hard / Soft / Technical / Data / Integration — low-variability, kept free-text rather than a hardcoded Prisma enum for forward safety
  status             String? // Clear / At Risk / Blocked / Resolved
  impactIfBlocked    String?
  notes              String?

  @@unique([releaseId, dependsOnReleaseId])
}

model ReleaseAuditEvent {
  id        String   @id @default(cuid())
  releaseId String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  action    String
  actor     String
  detail    String?
  createdAt DateTime @default(now())
  @@index([releaseId, createdAt])
}

model EnvBooking {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applicationId   String
  application     Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  environmentId   String?
  environment     Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  bookedBy        String
  team            String
  departmentName  String?
  fromDate        DateTime
  toDate          DateTime
  purpose         String?
  releaseId       String?
  release         Release?     @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  status          String       @default("BOOKED")

  releaseSize     String?
  prodReleaseDate DateTime?
  cabDate         DateTime?
  testEnvCode     String?
  testStart       DateTime?
  testEnd         DateTime?
  testDays        Int?
  uatEnvCode      String?
  uatStart        DateTime?
  uatEnd          DateTime?
  uatDays         Int?
  preProdEnvCode  String?
  preProdStart    DateTime?
  preProdEnd      DateTime?
  preProdDays     Int?
  conflictFlag    Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  @@index([organizationId, releaseId])
  @@index([environmentId, fromDate, toDate])
  @@index([applicationId, fromDate, toDate])
}

model SystemMappingGroup {
  id          String              @id @default(cuid())
  name        String
  status      String              @default("accepted")
  sourceNotes String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  edges       SystemMappingEdge[]
}

// Kept for genuine per-environment integration mapping when that data
// exists — NOT used for the workbook's System Mapping sheet, which has
// no environment granularity (see SystemIntegration below instead).
model SystemMappingEdge {
  id           String               @id @default(cuid())
  groupId      String?
  group        SystemMappingGroup?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sourceAppId  String
  sourceApp    Application          @relation("MappingSourceApp", fields: [sourceAppId], references: [id], onDelete: Cascade)
  sourceEnvId  String
  sourceEnv    Environment          @relation("MappingSourceEnv", fields: [sourceEnvId], references: [id], onDelete: Cascade)
  targetAppId  String
  targetApp    Application          @relation("MappingTargetApp", fields: [targetAppId], references: [id], onDelete: Cascade)
  targetEnvId  String
  targetEnv    Environment          @relation("MappingTargetEnv", fields: [targetEnvId], references: [id], onDelete: Cascade)
  direction    String
  notes        String?
  isDefault    Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

// Matches the workbook's actual System Mapping sheet shape (app/department
// level, no environment granularity).
model SystemIntegration {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceAppId      String
  sourceApp        Application  @relation("IntegrationSource", fields: [sourceAppId], references: [id], onDelete: Cascade)
  departmentName   String?
  systemType       String?
  integratesWith   String
  dataFlow         String?
  keyDataExchanged String?
  createdAt        DateTime     @default(now())
}

// ═══════════════════════════════════════════════════════════════════
// CONNECTORS / INTEGRATION LAYER (unchanged from prior design)
// ═══════════════════════════════════════════════════════════════════

model Connector {
  id            String             @id @default(cuid())
  organizationId String
  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name          String
  type          String
  authType      String
  baseUrl       String?
  credentials   String
  config        Json?
  pollInterval  Int                @default(15)
  status        String             @default("PENDING")
  lastSyncedAt  DateTime?
  lastError     String?
  enabled       Boolean            @default(true)
  createdBy     String?
  syncLogs      ConnectorSyncLog[]
  workItems     WorkItem[]
  p1Issues      P1Issue[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model ConnectorSyncLog {
  id            String    @id @default(cuid())
  connectorId   String
  connector     Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String
  recordsSynced Int?      @default(0)
  errorMessage  String?

  @@index([connectorId])
  @@index([connectorId, startedAt])
}

model P1Issue {
  id          String     @id @default(cuid())
  externalId  String     @unique
  title       String
  application String?
  releaseCode String?
  priority    String     @default("P1")
  status      String
  source      String
  connectorId String?
  connector   Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@index([status])
}

model WorkItem {
  id          String     @id @default(cuid())
  externalId  String     @unique
  title       String
  itemType    String
  releaseCode String?
  status      String
  assignee    String?
  priority    String?
  blockedBy   String?
  source      String     @default("Jira")
  connectorId String?
  connector   Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([releaseCode])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════
// RELEASE STATE / HISTORY (unchanged)
// ═══════════════════════════════════════════════════════════════════

model ReleaseDecisionState {
  id         String    @id @default(cuid())
  releaseId  String    @unique
  decision   String?
  rationale  String?
  decidedAt  DateTime?
  decidedBy  String?
  overridden Boolean   @default(false)
  updatedAt  DateTime  @updatedAt
}

model DeploymentState {
  id                String    @id @default(cuid())
  releaseId         String    @unique
  phase             String
  startedAt         DateTime?
  rollbackNarrative String?
  rollbackReason    String?
  rolledBackAt      DateTime?
  updatedAt         DateTime  @updatedAt
}

model ReleaseHistoryEvent {
  id        String   @id @default(cuid())
  releaseId String
  timestamp DateTime @default(now())
  actor     String
  action    String
  type      String
  agent     String?

  @@index([releaseId])
  @@index([releaseId, timestamp])
}

model AppNotificationRow {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  title     String
  message   String
  releaseId String?
  read      Boolean  @default(false)
  type      String
}

model AgentPauseState {
  agentId   String   @id
  paused    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 1 — STAKEHOLDERS, RISK, DRIFT, APPROVALS, LEAVE, CALENDAR
// ═══════════════════════════════════════════════════════════════════

model ReleaseStakeholder {
  releaseId String
  userId    String
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([releaseId, userId])
}

model Risk {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  riskCode           String
  releaseId          String
  release            Release      @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  category           String
  description        String
  likelihood         Int
  impact             Int
  riskScore          Int
  affectedArea       String?
  mitigationStrategy String?
  riskOwnerId        String?
  riskOwner          User?        @relation(fields: [riskOwnerId], references: [id])
  status             String
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt           DateTime    @updatedAt

  @@unique([organizationId, riskCode])
  @@index([releaseId])
  @@index([organizationId, status])
}

model Drift {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driftCode         String
  releaseId         String
  release           Release      @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  applicationId     String
  application       Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  environmentName   String
  driftType         String
  driftCategory     String?      // free-text — confirmed real categories (e.g. "SSL Certificate Expiring") are far more specific than any fixed 6-value enum
  detectedDate      DateTime
  severity          String
  description       String
  impactOnRelease   String?
  remediationAction String?
  status            String
  etaToFix          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([organizationId, driftCode])
  @@index([releaseId])
  @@index([applicationId])
  @@index([organizationId, status])
}

model Approval {
  id            String       @id @default(cuid())
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvalCode  String
  releaseId     String
  release       Release      @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  approvalType  String       // free-text — confirmed real approval types include values (e.g. "Change Manager") not in any fixed default list
  approverId    String
  approver      User         @relation(fields: [approverId], references: [id])
  submittedDate DateTime
  decisionDate  DateTime?
  decision      String       @default("Pending")
  comments      String?
  cabMeetingId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([organizationId, approvalCode])
  @@index([releaseId])
  @@index([organizationId, decision])
}

model LeaveRecord {
  id               String               @id @default(cuid())
  organizationId   String
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaveCode        String
  userId           String
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveStart       DateTime
  leaveEnd         DateTime
  leaveType        String
  days             Int
  riskImpact       String?
  riskScore        Int
  affectedReleases LeaveRecordRelease[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([organizationId, leaveCode])
  @@index([userId])
  @@index([organizationId, leaveStart, leaveEnd])
}

model LeaveRecordRelease {
  leaveRecordId String
  releaseId     String
  leaveRecord   LeaveRecord @relation(fields: [leaveRecordId], references: [id], onDelete: Cascade)
  release       Release     @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@id([leaveRecordId, releaseId])
}

model CalendarEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime
  eventType      String
  releaseId      String?
  release        Release?     @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  title          String
  departmentName String?
  sizeImpact     String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([releaseId])
  @@index([organizationId, date])
}

model EnvironmentVersion {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  version       String
  updatedBy     String?
  buildNumber   String?
  deployDate    DateTime?
  status        String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([applicationId, environmentId])
}

// ═══════════════════════════════════════════════════════════════════
// NEW OPERATIONAL ENTITIES (V0.4 gap — Monitoring / Incidents / Status / Maintenance)
// ═══════════════════════════════════════════════════════════════════

model MonitoringAlert {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  alertCode       String
  timestamp       DateTime
  applicationId   String
  application     Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  departmentName  String?
  alertType       String       // free-text — confirmed 16 highly specific real values, no fixed enum viable
  severity        String
  metric          String
  threshold       String       // mixed units in source (0.85, "200ms") — always text, never coerced to Float
  currentValue    String
  status          String
  assignedTo      String?
  environmentName String?
  createdAt       DateTime     @default(now())

  @@unique([organizationId, alertCode])
  @@index([applicationId])
  @@index([organizationId, timestamp])
  @@index([organizationId, status])
}

model Incident {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incidentCode     String
  timestamp        DateTime
  applicationId    String
  application      Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  departmentName   String?
  severity         String       // P1/P2/P3
  title            String
  status           String
  impact           String?
  assignedTo       String?
  relatedReleaseId String?
  relatedRelease   Release?     @relation(fields: [relatedReleaseId], references: [id], onDelete: SetNull)
  environmentName  String?
  createdAt        DateTime     @default(now())

  @@unique([organizationId, incidentCode])
  @@index([applicationId])
  @@index([relatedReleaseId])
  @@index([organizationId, timestamp])
  @@index([organizationId, status])
}

model ApplicationStatusCheck {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applicationId   String
  application     Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  environmentName String
  status          String       // Healthy / Degraded / Down
  lastCheck       DateTime
  uptimePercent   Float?
  notes           String?
  updatedAt       DateTime     @updatedAt

  @@unique([applicationId, environmentName])
}

model PlannedMaintenance {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  maintenanceCode String
  scheduledDate   DateTime
  startTime       String       // "HH:MM" — source is a time-only cell
  endTime         String
  maintenanceType String
  applications    String       // comma-separated application names, as given in source
  environments    String       // comma-separated env names, as given in source
  departmentName  String?
  impact          String?
  requestor       String?
  approvalStatus  String?
  notes           String?
  createdAt       DateTime     @default(now())

  @@unique([organizationId, maintenanceCode])
  @@index([organizationId, scheduledDate])
}

// ═══════════════════════════════════════════════════════════════════
// SCORING ENGINE — Risk Factors, Thresholds, Scales, SLA Targets
// (Reference Data §7, §15, §18, §19, §24)
// ═══════════════════════════════════════════════════════════════════

model RiskFactorDefinition {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  category       String
  factorName     String
  weight         Float
  description    String?
  scoreBest      String?
  scoreWorst     String?
  dataSource     String?

  @@unique([organizationId, category, factorName])
}

model ReleaseRiskMetric {
  id          String   @id @default(cuid())
  releaseId   String
  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  metricName  String
  metricValue String   // stored as text; source mixes ints, decimals, percentages
  capturedAt  DateTime @default(now())

  @@index([releaseId])
}

model RiskScoreThreshold {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  riskLevel      String
  minScore       Float
  maxScore       Float
  colorCode      String?
  actionRequired String?
  approvalLevel  String?

  @@unique([organizationId, riskLevel])
}

model RiskLikelihoodScale {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  score            Int
  label            String
  probabilityRange String?
  description      String?

  @@unique([organizationId, score])
}

model RiskImpactScale {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  score               Int
  label               String
  businessImpactRange String?
  description         String?

  @@unique([organizationId, score])
}

model SLAMetricDefinition {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  metricName           String
  target               String
  warning              String
  critical             String
  measurementFrequency String?

  @@unique([organizationId, metricName])
}

// ═══════════════════════════════════════════════════════════════════
// WORKFLOW ENGINE — Release Status, Approval Types, Roles, Testing Gates
// (Reference Data §6, §8, §12, §22)
// Starts EMPTY per org on signup — no auto-seeded defaults, org configures manually.
// ═══════════════════════════════════════════════════════════════════

model WorkflowStageDefinition {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  entityType     String       // "Release", "Drift", "Incident" — which workflow this stage belongs to
  stageCode      String       // org-defined, e.g. "PLANNING"
  displayName    String
  stage          String?      // grouping label, e.g. "Review", "Active", "Closed"
  sequence       Int
  systemTag      String       // fixed tag the app's logic checks: DRAFT | IN_REVIEW | APPROVED | BLOCKED | TERMINAL_SUCCESS | TERMINAL_FAILURE | TERMINAL_CANCELLED
  colorCode      String?
  description    String?

  @@unique([organizationId, entityType, stageCode])
}

model ApprovalTypeDefinition {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  approvalType     String
  code             String
  approverRoleCode String?      // loosely references RoleDefinition.code — not a hard FK, keeps this configurable independently
  slaHours         Int?
  sequence         Int
  systemTag        String?      // e.g. "FINAL" to mark the terminal approval stage

  @@unique([organizationId, code])
}

model RoleDefinition {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  roleName         String
  code             String
  canCreateRelease Boolean      @default(false)
  canApprove       Boolean      @default(false)
  isAdmin          Boolean      @default(false)
  departmentScoped Boolean      @default(true)

  @@unique([organizationId, code])
}

model TestingPhaseGate {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  phaseName       String
  environmentName String?
  entryCriteria   String?
  exitCriteria    String?
  signOffRoleCode String?
  sequence        Int

  @@unique([organizationId, phaseName])
}

// ═══════════════════════════════════════════════════════════════════
// ALERT ENGINE — Notification routing (Reference Data §21)
// ═══════════════════════════════════════════════════════════════════

model NotificationTypeDefinition {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isSystemDefault Boolean      @default(false) // true = system template row (owned by the sentinel global org), clonable into a new org on request
  triggerEvent   String
  recipients     String[]     // fixed shape (array of role/user codes), not jsonb
  channels       String[]     // e.g. ["Email","Teams"]

  @@unique([organizationId, triggerEvent])
}

