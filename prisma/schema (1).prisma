// ═══════════════════════════════════════════════════════════════════
// DYNAMIC / CUSTOM FIELDS METADATA
// Drives which extra inputs render on Application/Environment/User/Release
// forms per organization. Values themselves live in each entity's
// customFields JSONB column above.
// ═══════════════════════════════════════════════════════════════════

model CustomFieldDefinition {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entityType     String       // "Application" | "Environment" | "User" | "Release"
  fieldName      String
  fieldType      String       // "text" | "number" | "dropdown" | "date"
  options        Json?        // dropdown choices, e.g. ["Gold","Silver","Bronze"]
  required       Boolean      @default(false)
  displayOrder   Int          @default(0)

  @@unique([organizationId, entityType, fieldName])
}
